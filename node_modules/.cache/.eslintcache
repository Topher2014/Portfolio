ntainer';\n\nimport movie from '../Assets/movie.png'\nimport workout from '../Assets/workout.png'\nimport commandLine from '../Assets/commandLine.png'\n\nconst BoxWithHover = styled(Box)`\n  transition: .5s;\n  &:hover {\n    transform: scale(1.05); /* Enlarge the image on hover */\n  }\n`;\n\nconst projectItem = (image, name, func) => {\n  return (\n    <Container\n      maxWidth='none'\n      onClick={func}\n      sx={{\n        display: 'flex', \n        flexDirection: 'row', \n        alignItems: 'center',\n        width: '100%',\n        mx: 'auto',\n        mb: '25vh',\n        cursor: 'pointer'\n      }}       \n    >\n      <BoxWithHover>\n        <Box \n          component='img'\n          src={image}\n          alt={`${name} logo`}\n          sx={{\n            height: '10vw',\n            mr: 2,\n          }}\n        />\n      </BoxWithHover>\n      <Typography variant='h3'>{name}</Typography>\n    </Container>\n  );\n};\n\nfunction Projects () {\n    const navigate = useNavigate();\n    const reroute = (path) => {\n        return () => navigate(path);\n        // return () => window.open(path, '_blank');\n    };\n\n    return (\n        <Container\n          maxWidth='none'\n          sx={{\n            display: 'flex', \n            flexDirection: 'column', \n            alignItems: 'center',\n            width: '100%',\n            mx: 'auto',\n            mb: '25vh'\n          }}        \n        >\n            <Typography \n              id='projects'\n              variant='h2' \n              my={4}\n            >\n              Projects\n            </Typography>\n            <Box sx={{ display: 'flex', justifyContent: 'center' }}>\n              {/* {projectItem(movie, 'Topher Emby', reroute('/TopherEmby') )}\n              {projectItem(commandLine, 'OnlyKyles', reroute('/OnlyKyles') )}\n              {projectItem(workout, 'Flat & Iron Abs', reroute('/FlatIronAbs') )} */}\n              {projectItem(movie, 'Topher Emby')}\n              {projectItem(commandLine, 'OnlyKyles')}\n              {projectItem(workout, 'Flat & Iron Abs')}\n            </Box>\n        </Container>\n    );\n}\n\nexport default Projects;","/home/topher/Desktop/Projects/portfolio2/src/Components/HireMe.js",["131"],[],"import React, { useEffect } from 'react';\nimport HIREME from '../Assets/HIRE_ME.mp3'\nconst HireMeComponent = () => {\n  useEffect(() => {\n    const audio = new Audio(HIREME);\n    const intervalId = setInterval(() => {\n      audio.play();\n    }, 1000); // Repeat every 1 second\n    return () => {\n      clearInterval(intervalId); // Clear the interval when the component unmounts\n      audio.pause(); // Pause the audio when the component unmounts\n    };\n  }, []);\n  return (\n    null\n  );\n};\nexport default HireMeComponent;",[],"/home/topher/Desktop/Projects/portfolio2/src/Components/Header.js",[],[],"/home/topher/Desktop/Projects/portfolio2/src/Components/Skills.js",[],[],"/home/topher/Desktop/Projects/portfolio2/src/Components/TopherEmby.js",[],[],"/home/topher/Desktop/Projects/portfolio2/src/Components/ProjectCard.js",[],[],"/home/topher/Desktop/Projects/portfolio2/src/Components/Home.js",[],[],"/home/topher/Desktop/Projects/Portfolio/src/index.js",[],[],[],"/home/topher/Desktop/Projects/Portfolio/src/App.js",["132"],[],"import HireMe from './Components/HireMe'\nimport Home from './Components/Home'\nimport TopherEmby from './Components/TopherEmby'\nimport OnlyKyles from './Components/OnlyKyles'\nimport FlatIronAbs from './Components/FlatIronAbs'\nimport { BrowserRouter, Route, Routes } from 'react-router-dom'\n\nfunction App() {\n    return (\n        <>\n        <BrowserRouter>\n            <Routes>\n                <Route path='/' element={<Home />} />\n                <Route path='/TopherEmby' element={<TopherEmby />} />\n                <Route path='/OnlyKyles' element={<OnlyKyles />} />\n                <Route path='/FlatIronAbs' element={<FlatIronAbs />} />\n            </Routes>\n        </BrowserRouter>\n        </>\n    )\n}\n\nexport default App","/home/topher/Desktop/Projects/Portfolio/src/Components/Home.js",[],[],"/home/topher/Desktop/Projects/Portfolio/src/Components/TopherEmby.js",[],[],"/home/topher/Desktop/Projects/Portfolio/src/Components/HireMe.js",["133"],[],"/home/topher/Desktop/Projects/Portfolio/src/Components/Projects.js",[],[],"/home/topher/Desktop/Projects/Portfolio/src/Components/Skills.js",[],[],"/home/topher/Desktop/Projects/Portfolio/src/Components/About.js",["134"],[],"/home/topher/Desktop/Projects/Portfolio/src/Components/Contact.js",[],[],"/home/topher/Desktop/Projects/Portfolio/src/Components/Header.js",[],[],"/home/topher/Desktop/Projects/Portfolio/src/Components/ProjectCard.js",[],[],"/home/topher/Desktop/Projects/Portfolio/src/Components/OnlyKyles.js",[],[],"/home/topher/Desktop/Projects/Portfolio/src/Components/FlatIronAbs.js",[],[],{"ruleId":"135","severity":1,"message":"136","line":1,"column":8,"nodeType":"137","messageId":"138","endLine":1,"endColumn":14},{"ruleId":"135","severity":1,"message":"139","line":11,"column":7,"nodeType":"137","messageId":"138","endLine":11,"endColumn":15},{"ruleId":"135","severity":1,"message":"140","line":51,"column":11,"nodeType":"137","messageId":"138","endLine":51,"endColumn":18},{"ruleId":"135","severity":1,"message":"141","line":1,"column":8,"nodeType":"137","messageId":"138","endLine":1,"endColumn":13},{"ruleId":"135","severity":1,"message":"136","line":1,"column":8,"nodeType":"137","messageId":"138","endLine":1,"endColumn":14},{"ruleId":"135","severity":1,"message":"141","line":1,"column":8,"nodeType":"137","messageId":"138","endLine":1,"endColumn":13},{"ruleId":"135","severity":1,"message":"139","line":16,"column":7,"nodeType":"137","messageId":"138","endLine":16,"endColumn":15},"no-unused-vars","'HireMe' is defined but never used.","Identifier","unusedVar","'gridItem' is assigned a value but never used.","'reroute' is assigned a value but never used.","'React' is defined but never used."]